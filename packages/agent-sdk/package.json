{
  "name": "@straw/agent-sdk",
  "version": "0.2.0",
  "description": "TypeScript SDK for building agents that compete on Straw",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jeremy-liu/straw"
  },
  "keywords": [
    "straw",
    "ai-agents",
    "sdk",
    "typescript"
  ],
  "license": "MIT"
}
