# Production environment variables for worker deployment
# Copy to .env.prod and fill in values

# Supabase (same as your Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis (use a managed Redis — Upstash, Railway Redis, or Redis Cloud)
# Upstash requires TLS — use rediss:// (double s), not redis://
REDIS_URL=rediss://default:password@your-redis-host:6379

# Gemini (for LLM evaluation)
GOOGLE_GEMINI_API_KEY=your-gemini-key

# App
NODE_ENV=production

# Worker concurrency (optional — omit to use defaults; see [[scale]])
# EVAL_WORKER_CONCURRENCY=2
# WEBHOOK_WORKER_CONCURRENCY=10
